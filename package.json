{
  "name": "vyana-backend",
  "version": "1.0.0",
  "description": "Backend API for Vyana menstrual wellness app",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "migrate": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "demo:insights": "ts-node --transpile-only scripts/run-menstrual-insight-demo.ts",
    "test:scenarios": "ts-node --transpile-only scripts/run-scenarios.ts",
    "test": "jest",
    "test:unit": "jest --testPathPatterns=tests/units",
    "test:integration": "jest --testPathPatterns=tests/integration",
    "test:fuzz": "jest --testPathPatterns=fuzz",
    "test:coverage": "jest --coverage --testPathPatterns=tests/units"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhirajsinha/vyana-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/abhirajsinha/vyana-backend/issues"
  },
  "homepage": "https://github.com/abhirajsinha/vyana-backend#readme",
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.32.0",
    "prisma": "^6.19.2"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
